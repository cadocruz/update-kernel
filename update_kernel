#!/bin/bash

# Configurações de segurança e erro
set -eo pipefail

# 1. Garantir privilégios de root (pedir sudo se não for root)
if [ "$EUID" -ne 0 ]; then
    echo "Privilégios de root requeridos. Executando com sudo..."
    exec sudo "$0" "$@"
fi

# 2. Obter o diretório home do usuário original (mesmo sob sudo)
if [ -n "$SUDO_USER" ]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    USER_HOME="$HOME"
fi

# Variáveis de controle
ONLY_COMPILE=false
TARGET_DIR=""
LINK=""

# Parse de argumentos
while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -c|--only-compile|--compile)
            ONLY_COMPILE=true
            if [[ -n "$2" && "$2" != -* ]]; then
                TARGET_DIR="$2"
                shift
            fi
            ;;
        *)
            echo "Opção desconhecida: $1" >&2
            echo "Uso: $0 [-c|--only-compile] [/opt/linux-version]" >&2
            exit 1
            ;;
    esac
    shift
done

# Função para obter a URL da versão estável mais recente do kernel.org
get_latest_stable_url() {
    local json
    json=$(curl -s https://www.kernel.org/releases.json || wget -qO- https://www.kernel.org/releases.json || true)
    if [ -z "$json" ]; then
        return 1
    fi
    
    # Tenta usar jq se disponível
    if command -v jq >/dev/null 2>&1; then
        echo "$json" | jq -r '.releases[] | select(.moniker == "stable" and .version == .latest_stable.version) | .source' && return 0
    fi
    
    # Tenta usar python3 se disponível
    if command -v python3 >/dev/null 2>&1; then
        echo "$json" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    latest = data.get('latest_stable', {}).get('version')
    for rel in data.get('releases', []):
        if rel.get('moniker') == 'stable' and rel.get('version') == latest:
            print(rel.get('source'))
            sys.exit(0)
except Exception:
    sys.exit(1)
" && return 0
    fi
    
    # Fallback usando grep se nada mais estiver instalado
    echo "$json" | grep -oP '"moniker":\s*"stable".*?"source":\s*"\K[^"]+' | head -n 1
}

# Se não foi forçado o modo de apenas compilar por argumento, oferece menu interativo
if [ "$ONLY_COMPILE" = false ]; then
    echo "=== Assistente de Instalação e Compilação do Kernel Linux ==="
    echo "Selecione uma opção:"
    echo "1) Baixar e instalar a versão estável mais recente do kernel.org"
    echo "2) Baixar e instalar a partir de um link personalizado"
    echo "3) Apenas compilar e instalar a partir de um diretório existente em /opt"
    read -p "Opção (padrão: 1): " OPTION
    
    case "$OPTION" in
        2)
            read -p "Digite o link do arquivo do kernel (.tar.xz ou .tar.gz): " LINK
            if [ -z "$LINK" ]; then
                echo "Erro: O link não pode ser vazio." >&2
                exit 1
            fi
            ;;
        3)
            ONLY_COMPILE=true
            ;;
        *)
            # Padrão: Opção 1, vamos buscar o link automático mais tarde
            ;;
    esac
fi

# Resolução do diretório para compilação caso esteja no modo apenas compilar
if [ "$ONLY_COMPILE" = true ]; then
    if [ -z "$TARGET_DIR" ]; then
        echo "Buscando diretórios do kernel disponíveis em /opt..."
        shopt -s nullglob
        dirs=(/opt/linux-*)
        shopt -u nullglob
        
        if [ ${#dirs[@]} -eq 0 ]; then
            echo "Erro: Nenhum diretório de kernel (/opt/linux-*) encontrado em /opt." >&2
            exit 1
        fi
        
        echo "Selecione o diretório do kernel para compilar:"
        for i in "${!dirs[@]}"; do
            echo "$((i+1))) ${dirs[i]}"
        done
        
        read -p "Escolha o número: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#dirs[@]}" ]; then
            TARGET_DIR="${dirs[$((choice-1))]}"
        else
            echo "Erro: Escolha inválida." >&2
            exit 1
        fi
    fi
    
    if [ ! -d "$TARGET_DIR" ]; then
        echo "Erro: O diretório '$TARGET_DIR' não existe." >&2
        exit 1
    fi
fi

# Chaves MOK
MOK_KEY="$USER_HOME/MOK.priv"
MOK_CERT="$USER_HOME/MOK.pem"

# Se NÃO estiver no modo apenas compilar, realizar download e preparação
if [ "$ONLY_COMPILE" = false ]; then
    # Se a opção 1 foi selecionada (ou padrão) e LINK ainda não foi definido
    if [ -z "$LINK" ]; then
        echo "Buscando informações da versão estável mais recente no kernel.org..."
        LATEST_URL=$(get_latest_stable_url || true)
        
        if [ -n "$LATEST_URL" ]; then
            LATEST_VERSION=$(basename "$LATEST_URL" | sed -r 's/linux-(.+)\.tar\.(xz|gz)/\1/')
            echo "Versão estável mais recente detectada: $LATEST_VERSION"
            echo "Link: $LATEST_URL"
            
            if [ -d "/opt/linux-$LATEST_VERSION" ]; then
                echo "Aviso: A versão $LATEST_VERSION já está descompactada em /opt/linux-$LATEST_VERSION."
            fi
            
            read -p "Pressione Enter para prosseguir com a versão $LATEST_VERSION, digite 'n' para cancelar ou cole um link personalizado: " USER_INPUT
            
            if [ -z "$USER_INPUT" ] || [ "$USER_INPUT" = "s" ] || [ "$USER_INPUT" = "S" ]; then
                LINK="$LATEST_URL"
            elif [ "$USER_INPUT" = "n" ] || [ "$USER_INPUT" = "N" ]; then
                echo "Cancelado pelo usuário."
                exit 0
            elif [[ "$USER_INPUT" =~ ^https?:// ]]; then
                LINK="$USER_INPUT"
            else
                echo "Erro: Entrada inválida." >&2
                exit 1
            fi
        else
            echo "Aviso: Não foi possível obter informações do kernel.org de forma automática."
            read -p "Digite o link do arquivo do kernel (.tar.xz ou .tar.gz) manualmente: " LINK
            if [ -z "$LINK" ]; then
                echo "Erro: O link não pode ser vazio." >&2
                exit 1
            fi
        fi
    fi

    # Preparar diretório temporário para download/descompressão
    TEMP_DIR=$(mktemp -d)
    cleanup() {
        local exit_code=$?
        rm -rf "$TEMP_DIR"
        exit $exit_code
    }
    trap cleanup EXIT INT TERM ERR

    # Detectar o diretório do kernel anterior antes de descompactar o novo
    echo "Buscando versão do kernel anterior em /opt..."
    PREV_KERNEL_DIR=$(ls -d /opt/linux-* 2>/dev/null | sort -V | tail -n 1 || true)
    if [ -n "$PREV_KERNEL_DIR" ]; then
        echo "Kernel anterior encontrado: $PREV_KERNEL_DIR"
    else
        echo "Nenhum diretório de kernel anterior encontrado em /opt."
    fi

    # Baixar
    echo "Baixando o arquivo do kernel de $LINK..."
    if command -v curl >/dev/null 2>&1; then
        curl -L "$LINK" -o "$TEMP_DIR/archive.tar"
    elif command -v wget >/dev/null 2>&1; then
        wget -O "$TEMP_DIR/archive.tar" "$LINK"
    else
        echo "Erro: Instale curl ou wget para continuar." >&2
        exit 1
    fi

    # Descompactar
    echo "Descompactando o kernel..."
    mkdir -p "$TEMP_DIR/extracted"
    tar -xf "$TEMP_DIR/archive.tar" -C "$TEMP_DIR/extracted"

    EXTRACTED_FOLDER=$(find "$TEMP_DIR/extracted" -mindepth 1 -maxdepth 1 -type d | head -n 1)
    if [ -z "$EXTRACTED_FOLDER" ]; then
        echo "Erro: Pasta do kernel não encontrada no arquivo descompactado." >&2
        exit 1
    fi

    FOLDER_NAME=$(basename "$EXTRACTED_FOLDER")
    TARGET_DIR="/opt/$FOLDER_NAME"

    # Se o diretório de destino já existir, criar backup
    if [ -d "$TARGET_DIR" ]; then
        BACKUP_PATH="${TARGET_DIR}.bak.$(date +%Y%m%d%H%M%S)"
        echo "Aviso: O diretório $TARGET_DIR já existe. Movendo antigo para $BACKUP_PATH..."
        mv "$TARGET_DIR" "$BACKUP_PATH"
    fi

    # Mover para /opt
    echo "Instalando código fonte do kernel em $TARGET_DIR..."
    mv "$EXTRACTED_FOLDER" "$TARGET_DIR"

    # Copiar o .config
    if [ -n "$PREV_KERNEL_DIR" ] && [ -f "$PREV_KERNEL_DIR/.config" ]; then
        echo "Copiando .config de: $PREV_KERNEL_DIR"
        cp "$PREV_KERNEL_DIR/.config" "$TARGET_DIR/.config"
    elif [ -f "/boot/config-$(uname -r)" ]; then
        echo "Aviso: .config não encontrado em $PREV_KERNEL_DIR. Copiando configuração do kernel em execução (/boot/config-$(uname -r))...."
        cp "/boot/config-$(uname -r)" "$TARGET_DIR/.config"
    else
        echo "Aviso: Nenhum arquivo .config anterior encontrado."
    fi
fi

# --- Execução comum (Entrar no diretório e realizar compilação/instalação) ---
cd "$TARGET_DIR"

# Detectar versão do kernel
VERSION=$(make -s kernelversion 2>/dev/null || echo "$(basename "$TARGET_DIR" | sed 's/linux-//')")
echo "Iniciando processo de compilação para o kernel versão: $VERSION (Diretório: $TARGET_DIR)"

# Se não estiver no modo apenas compilar e não houver .config, gera padrão
if [ "$ONLY_COMPILE" = false ]; then
    if [ ! -f ".config" ]; then
        echo "Inicializando configuração padrão (defconfig)..."
        make defconfig
    fi
    
    echo "Preparando a configuração local baseada nos módulos ativos (make localmodconfig)..."
    make localmodconfig
else
    # No modo apenas compilar, garante que exista um .config
    if [ ! -f ".config" ]; then
        echo "Erro: Nenhum arquivo .config encontrado em $TARGET_DIR." >&2
        echo "Por favor, configure o kernel antes de rodar a compilação (ex: make menuconfig)." >&2
        exit 1
    fi
fi

# Compilar
echo "Compilando o kernel (make -j\$(nproc))..."
make -j$(nproc)

# Instalar módulos e kernel
echo "Instalando módulos do kernel..."
make modules_install

echo "Instalando o kernel..."
make install

# Atualizar initramfs
echo "Preparando a atualização de initramfs..."
# Deleta o arquivo antigo se existir, para evitar erro de "Já existe" ao rodar com -c
rm -f "/boot/initrd.img-$VERSION" "/boot/initramfs-$VERSION.img" 2>/dev/null || true
echo "Atualizando initramfs para a versão $VERSION..."
update-initramfs -c -k "$VERSION"

# Atualizar GRUB
echo "Atualizando o menu do GRUB..."
update-grub

# Assinatura do Kernel para Secure Boot
echo "Iniciando assinatura do kernel para Secure Boot..."
if [ -f "$MOK_KEY" ] && [ -f "$MOK_CERT" ]; then
    VMLINUZ_FILE="/boot/vmlinuz-$VERSION"
    if [ ! -f "$VMLINUZ_FILE" ]; then
        local found_files=(/boot/vmlinuz-*"$VERSION"*)
        if [ -f "${found_files[0]}" ]; then
            VMLINUZ_FILE="${found_files[0]}"
        fi
    fi

    if [ -f "$VMLINUZ_FILE" ]; then
        echo "Assinando o arquivo: $VMLINUZ_FILE"
        sbsign --key "$MOK_KEY" --cert "$MOK_CERT" "$VMLINUZ_FILE" --output "$VMLINUZ_FILE"
        echo "Kernel assinado com sucesso!"
    else
        echo "Erro: Arquivo do kernel correspondente a $VERSION não encontrado em /boot." >&2
        exit 1
    fi
else
    echo "Erro: Chave MOK ($MOK_KEY) ou certificado ($MOK_CERT) não encontrado." >&2
    echo "Por favor, garanta que MOK.priv e MOK.pem estão no diretório home do seu usuário original." >&2
    exit 1
fi

echo "Processo concluído com sucesso para a versão $VERSION!"
